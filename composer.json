{
    "name": "szepeviktor/test-mode",
    "description": "Switch to Test/Sandbox Mode",
    "type": "wordpress-plugin",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SzepeViktor\\TestMode\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Viktor Szépe",
            "email": "viktor@szepe.net"
        }
    ],
    "require": {
        "php": "~7.4.0 || ^8.0",
        "composer-runtime-api": "^2.2"
    },
    "require-dev": {
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "scripts": {
        "make-pot": "wp i18n make-pot . languages/szv-test-mode.pot --headers='{\"Report-Msgid-Bugs-To\":\"https://github.com/szepeviktor/test-mode/issues\"}'"
    }
}
